#!/usr/bin/env bash
set -euo pipefail

remote="${1:-origin}"

url="$(git remote get-url "$remote" 2>/dev/null)" || {
  echo "error: not a git repo, or remote '$remote' does not exist" >&2
  exit 1
}

new_url=""

case "$url" in
  git@*:*)
    # git@github.com:user/repo.git -> https://github.com/user/repo.git
    host="${url#git@}"
    host="${host%%:*}"

    path="${url#git@*:}"

    new_url="https://${host}/${path}"
    ;;

  ssh://git@*/*)
    # ssh://git@github.com/user/repo.git -> https://github.com/user/repo.git
    rest="${url#ssh://git@}"

    host="${rest%%/*}"
    path="${rest#*/}"

    new_url="https://${host}/${path}"
    ;;

  https://*|http://*)
    echo "remote '$remote' is already HTTP(S):"
    echo "$url"
    exit 0
    ;;

  *)
    echo "error: unsupported remote URL format:" >&2
    echo "$url" >&2
    exit 1
    ;;
esac

echo "Changing remote '$remote':"
echo "  from: $url"
echo "  to:   $new_url"

git remote set-url "$remote" "$new_url"

echo "done"
