#!/usr/bin/env bash
set -euo pipefail

remote="${1:-origin}"

url="$(git remote get-url "$remote" 2>/dev/null)" || {
  echo "error: not a git repo, or remote '$remote' does not exist" >&2
  exit 1
}

new_url=""

case "$url" in
  https://*/*|http://*/*)
    # https://github.com/user/repo.git -> git@github.com:user/repo.git
    rest="${url#https://}"
    rest="${rest#http://}"

    host="${rest%%/*}"
    path="${rest#*/}"

    if [[ -z "$host" || -z "$path" || "$host" == "$path" ]]; then
      echo "error: invalid HTTP(S) remote URL:" >&2
      echo "$url" >&2
      exit 1
    fi

    # Normal case:
    #   https://github.com/user/repo.git
    # becomes:
    #   git@github.com:user/repo.git
    new_url="git@${host}:${path}"
    ;;

  git@*:*)
    echo "remote '$remote' is already SSH:"
    echo "$url"
    exit 0
    ;;

  ssh://git@*/*)
    echo "remote '$remote' is already SSH:"
    echo "$url"
    exit 0
    ;;

  *)
    echo "error: unsupported remote URL format:" >&2
    echo "$url" >&2
    exit 1
    ;;
esac

echo "Changing remote '$remote':"
echo "  from: $url"
echo "  to:   $new_url"

git remote set-url "$remote" "$new_url"

echo "done"
