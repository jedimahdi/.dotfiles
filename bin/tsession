#!/bin/sh
set -eu

pick_session() {
  {
    printf "%s\n" ".dotfiles" ".config/nvim"
    fd . apps --base-directory="$HOME" --exact-depth=2 --type d --color=never --format '{}' --no-ignore 2>/dev/null
  } | fzf \
    --border rounded \
    --scheme path \
    --height 100% \
    --preview 'eza $HOME/{} --color=always --icons -l --group-directories-first --no-user --no-time --no-filesize --no-permissions' \
    --preview-window=right:50%
}

selected="${1:-$(pick_session)}"
[ -z "$selected" ] && exit 0

# Handle both absolute and relative paths
case "$selected" in
/*) selected_path="$selected" ;;
*) selected_path="$HOME/$selected" ;;
esac

selected_name=$(basename "$selected_path" | tr . _)

exec tconnect "$selected_path" "$selected_name"
